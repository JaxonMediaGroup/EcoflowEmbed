# ── Chatbot Insights API Environment ──

# Main Flowise instance
FLOWISE_URL=https://your-flowise.example.com
FLOWISE_API_KEY=your-flowise-api-key

# Dashboard API (upstream analytics) — internal in Docker, no need to change
UPSTREAM_URL=http://127.0.0.1:5050

# OpenAI for AI enrichment (optional — the app works without it)
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ── Security (REQUIRED for production) ──

# Shared secret — frontends must send this in X-API-Key header
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET=

# Comma-separated list of allowed frontend origins (CORS)
# Example: https://dashboard.koppi.mx,https://admin.koppi.mx
ALLOWED_ORIGINS=
